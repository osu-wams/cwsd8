    "conflict": {
        "drupal/drupal": "*"
    },
    "autoload": {
        "classmap": [
            "scripts/composer/SiteGenerator.php"
        ]
    },
    "scripts": {
        "generate-site": "osuwams\\SiteGenerator::generate",
        "post-drupal-scaffold-cmd": [
            "cd docroot && patch -p1 <../patches/htaccess-updats.patch"
        ],
        "post-install-cmd": [
            "./scripts/highcharts-post-install.sh"
        ],
        "post-update-cmd": [
            "./scripts/highcharts-post-install.sh"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "preferred-install": "dist",
        "platform": {
            "php": "8.3"
        },
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true,
            "cweagans/composer-patches": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "drupal/core-composer-scaffold": true,
            "mnsami/composer-custom-directory-installer": true,
            "oomphinc/composer-installers-extender": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true,
            "tbachert/spi": true,
            "wikimedia/composer-merge-plugin": true
        },
        "audit": {
            "ignore": ["SA-CONTRIB-2025-077"]
        }
    },
    "extra": {
        "merge-plugin": {
            "include": [
                "docroot/modules/contrib/*/composer.libraries.json"
            ]
        },
        "composer-exit-on-patch-failure": true,
        "patchLevel": {
            "drupal/core": "-p2"
        },
        "patches": {
            "drupal/core": {
                "3049332-118 Layout Builder getEntityTypeId null": "https://www.drupal.org/files/issues/2024-06-26/3049332_d10.3.0.patch",
                "3162699-13 Layout Builder Debuging patch": "https://www.drupal.org/files/issues/2020-08-10/3162699-blockbuild-13.patch",
                "2605218-135 Views Block Display skips preBlockBuild() call on ajax rebuild": "https://www.drupal.org/files/issues/2024-06-13/2605218-135.patch",
                "3123350-29 Private File Migration path fix": "https://www.drupal.org/files/issues/2022-10-10/patch-29.patch",
                "3080034 Entity Reference Sort Migrate error": "patches/3080034-migrate-entity-reference-filter-null_local_1.patch",
                "2708101-130 Allow link fields to set default values": "https://www.drupal.org/files/issues/2024-07-15/default_value_for_link-2708101-130.patch",
                "2980299-105 Allow reverting all layouts that were overriden for a node type": "https://www.drupal.org/files/issues/2022-12-30/2980299-105.patch",
                "3311558-3 View mode for Caption Media Embed":"https://www.drupal.org/files/issues/2022-09-29/3311558-caption-view-mode.patch",
